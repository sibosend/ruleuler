# ─── 数据库 ───────────────────────────────────────────
MYSQL_ROOT_PASSWORD=change_me_root_pwd
MYSQL_USER=ruleuler
MYSQL_PASSWORD=change_me_pwd
MYSQL_DATABASE=ruleuler_data
MYSQL_PORT=3307

# ─── 认证 ─────────────────────────────────────────────
AUTH_JWT_SECRET=change_me_at_least_32_bytes_long_secret!!
AUTH_JWT_EXPIRATION_HOURS=24

# ─── 端口 ─────────────────────────────────────────────
SERVER_PORT=16009
CLIENT_PORT=16001

# ─── 管理后台地址（生产填实际域名） ───────────────────
ADMIN_BASE_URL=http://localhost:16009/admin

# ─── JVM ──────────────────────────────────────────────
SERVER_JAVA_OPTS=-Xms512m -Xmx2g
CLIENT_JAVA_OPTS=-Xms256m -Xmx1g

# ─── 日志和时区 ──────────────────────────────────────
LOG_DIR=./logs
TZ=Asia/Shanghai
