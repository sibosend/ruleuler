e><end name=\"结束\" x=\"1090\" y=\"200\" width=\"40\" height=\"70\"/></rule-flow>","create_user":"admin","update_user":"admin","company_id":null,"created_at":1774629361000,"updated_at":1774756964000},{"project":"airport_gate_allocation_db","path":"/airport_gate_allocation_db/flight_info.vl.xml","name":"flight_info.vl.xml","is_dir":false,"content":"<?xml version=\"1.0\" encoding=\"utf-8\"?>\n<variable-library>\n  <category name=\"FlightInfo\" clazz=\"FlightInfo\" type=\"GeneralEntity\">\n    <var name=\"aircraft_type\" label=\"aircraft_type\" type=\"String\" act=\"InOut\"/>\n    <var name=\"flight_number\" label=\"flight_number\" type=\"String\" act=\"InOut\"/>\n    <var name=\"passenger_count\" label=\"passenger_count\" type=\"Integer\" act=\"InOut\"/>\n    <var name=\"is_international\" label=\"is_international\" type=\"Boolean\" act=\"InOut\"/>\n    <var name=\"arrival_time\" label=\"arrival_time\" type=\"Integer\" act=\"InOut\"/>\n  </category>\n</variable-library>","create_user":"admin","update_user":"admin","company_id":null,"created_at":1774629991000,"updated_at":1774629991000},{"project":"airport_gate_allocation_db","path":"/airport_gate_allocation_db/gate_result.vl.xml","name":"gate_result.vl.xml","is_dir":false,"content":"<?xml version=\"1.0\" encoding=\"utf-8\"?>\n<variable-library>\n  <category name=\"GateResult\" clazz=\"GateResult\" type=\"GeneralEntity\">\n    <var name=\"assigned_gate\" label=\"assigned_gate\" type=\"String\" act=\"InOut\"/>\n    <var name=\"gate_type\" label=\"gate_type\" type=\"String\" act=\"InOut\"/>\n    <var name=\"priority_score\" label=\"priority_score\" type=\"Integer\" act=\"InOut\"/>\n    <var name=\"reason\" label=\"reason\" type=\"String\" act=\"InOut\"/>\n  </category>\n</variable-library>","create_user":"admin","update_user":"admin","company_id":null,"created_at":1774629991000,"updated_at":1774629991000},{"project":"airport_gate_allocation_db","path":"/airport_gate_allocation_db/intl_rules","name":"intl_rules","is_dir":true,"content":null,"create_user":"admin","update_user":"admin","company_id":null,"created_at":1774755798000,"updated_at":1774755798000},{"project":"airport_gate_allocation_db","path":"/airport_gate_allocation_db/intl_rules/asia","name":"asia","is_dir":true,"content":null,"create_user":"admin","update_user":"admin","company_id":null,"created_at":1774755798000,"updated_at":1774755798000},{"project":"airport_gate_allocation_db","path":"/airport_gate_allocation_db/intl_rules/asia/asia_gate_rules.rs.xml","name":"asia_gate_rules.rs.xml","is_dir":false,"content":"<?xml version=\"1.0\" encoding=\"utf-8\"?>\n<rule-set>\n  <import-variable-library path=\"dbr:/airport_gate_allocation_db/flight_info.vl.xml\"/>\n  <import-variable-library path=\"dbr:/airport_gate_allocation_db/gate_result.vl.xml\"/>\n  <rule name=\"亚洲航线近机位\" salience=\"5\">\n    <if><and>\n      <atom op=\"Equals\">\n        <left var-category=\"FlightInfo\" var=\"is_international\" var-label=\"is_international\" datatype=\"Boolean\"/>\n        <value content=\"true\" type=\"Input\"/>\n      </atom>\n      <atom op=\"GreaterThen\">\n        <left var-category=\"FlightInfo\" var=\"passenger_count\" var-label=\"passenger_count\" datatype=\"Integer\"/>\n        <value content=\"200\" type=\"Input\"/>\n      </atom>\n    </and></if>\n    <then>\n      <var-assign var-category=\"GateResult\" var=\"gate_type\" var-label=\"gate_type\" datatype=\"String\"><value content=\"近机位\" type=\"Input\"/></var-assign>\n      <var-assign var-category=\"GateResult\" var=\"assigned_gate\" var-label=\"assigned_gate\" datatype=\"String\"><value content=\"B区-203\" type=\"Input\"/></var-assign>\n      <var-assign var-category=\"GateResult\" var=\"reason\" var-label=\"reason\" datatype=\"String\"><value content=\"亚洲航线大客流近机位\" type=\"Input\"/></var-assign>\n    </then>\n  </rule>\n</rule-set>","create_user":"admin","update_user":"admin","company_id":null,"created_at":1774755798000,"updated_at":1774755798000},{"project":"airport_gate_allocation_db","path":"/airport_gate_allocation_db/intl_rules/europe_gate_rules.rs.xml","name":"europe_gate_rules.rs.xml","is_dir":false,"content":"<?xml version=\"1.0\" encoding=\"utf-8\"?>\n<rule-set>\n  <import-variable-library path=\"dbr:/airport_gate_allocation_db/flight_info.vl.xml\"/>\n  <import-variable-library path=\"dbr:/airport_gate_allocation_db/gate_result.vl.xml\"/>\n  <rule name=\"欧洲航线远机位\" salience=\"3\">\n    <if><and>\n      <atom op=\"Equals\">\n        <left var-category=\"FlightInfo\" var=\"is_international\" var-label=\"is_international\" datatype=\"Boolean\"/>\n        <value content=\"true\" type=\"Input\"/>\n      </atom>\n      <atom op=\"LessThenEquals\">\n        <left var-category=\"FlightInfo\" var=\"passenger_count\" var-label=\"passenger_count\" datatype=\"Integer\"/>\n        <value content=\"100\" type=\"Input\"/>\n      </atom>\n    </and></if>\n    <then>\n      <var-assign var-category=\"GateResult\" var=\"gate_type\" var-label=\"gate_type\" datatype=\"String\"><value content=\"远机位\" type=\"Input\"/></var-assign>\n      <var-assign var-category=\"GateResult\" var=\"reason\" var-label=\"reason\" datatype=\"String\"><value content=\"欧洲航线小客流远机位\" type=\"Input\"/></var-assign>\n    </then>\n  </rule>\n</rule-set>","create_user":"admin","update_user":"admin","company_id":null,"created_at":1774755798000,"updated_at":1774755798000},{"project":"airport_gate_allocation_db","path":"/airport_gate_allocation_db/common_libs","name":"common_libs","is_dir":true,"content":null,"create_user":"admin","update_user":"admin","company_id":null,"created_at":1774755798000,"updated_at":1774755798000},{"project":"airport_gate_allocation_db","path":"/airport_gate_allocation_db/common_libs/shared_vars.vl.xml","name":"shared_vars.vl.xml","is_dir":false,"content":"<?xml version=\"1.0\" encoding=\"utf-8\"?>\n<variable-library>\n  <category name=\"SharedVars\" clazz=\"SharedVars\" type=\"GeneralEntity\">\n    <var name=\"debug_mode\" label=\"debug_mode\" type=\"Boolean\" act=\"InOut\"/>\n  </category>\n</variable-library>","create_user":"admin","update_user":"admin","company_id":null,"created_at":1774755798000,"updated_at":1774755798000},{"project":"airport_gate_allocation_db","path":"/airport_gate_allocation_db/intl_rules/asia/asia_peak_rules.rea.xml","name":"asia_peak_rules.rea.xml","is_dir":false,"content":"<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n<rule-set>\n  <import-variable-library path=\"dbr:/airport_gate_allocation_db/common_libs/shared_vars.vl.xml\"/>\n  <import-variable-library path=\"dbr:/airport_gate_allocation_db/flight_info.vl.xml\"/>\n  <import-variable-library path=\"dbr:/airport_gate_allocation_db/gate_result.vl.xml\"/>\n  <import-parameter-library path=\"dbr:/airport_gate_allocation_db/canshu0.pl.xml\"/>\n  <import-parameter-library path=\"dbr:/airport_gate_allocation_db/canshu1.pl.xml\"/>\n  <rule name=\"亚洲高峰大客流\">\n    <if>\n  <and>\n    <atom op=\"GreaterThenEquals\">\n      <left var-category=\"FlightInfo\" var=\"arrival_time\" var-label=\"arrival_time\" datatype=\"Integer\" type=\"variable\">\n      </left>\n      <value content=\"5\" type=\"Input\"/>\n    </atom>\n    <atom op=\"LessThenEquals\">\n      <left var-category=\"FlightInfo\" var=\"arrival_time\" var-label=\"arrival_time\" datatype=\"Integer\" type=\"variable\">\n      </left>\n      <value content=\"10\" type=\"Input\"/>\n    </atom>\n    <atom op=\"Equals\">\n      <left var-category=\"FlightInfo\" var=\"is_international\" var-label=\"is_international\" datatype=\"Boolean\" type=\"variable\">\n      </left>\n      <value content=\"true\" type=\"Input\"/>\n    </atom>\n    <atom op=\"GreaterThen\">\n      <left var-category=\"FlightInfo\" var=\"passenger_count\" var-label=\"passenger_count\" datatype=\"Integer\" type=\"variable\">\n      </left>\n      <value content=\"180\" type=\"Input\"/>\n    </atom>\n  </and>\n    </if>\n    <then>\n  <var-assign var-category=\"GateResult\" var=\"gate_type\" var-label=\"gate_type\" datatype=\"String\" type=\"variable\">\n    <value content=\"近机位\" type=\"Input\"/>\n  </var-assign>\n  <var-assign var-category=\"GateResult\" var=\"assigned_gate\" var-label=\"assigned_gate\" datatype=\"String\" type=\"variable\">\n    <value content=\"B区-205\" type=\"Input\"/>\n  </var-assign>\n  <var-assign var-category=\"GateResult\" var=\"reason\" var-label=\"reason\" datatype=\"String\" type=\"variable\">\n    <value content=\"亚洲高峰时段大客流近机位\" type=\"Input\"/>\n  </var-assign>\n    </then>\n  </rule>\n  <rule name=\"亚洲低峰默认\">\n    <if>\n  <and>\n    <atom op=\"GreaterThen\">\n      <left var-category=\"FlightInfo\" var=\"arrival_time\" var-label=\"arrival_time\" datatype=\"Integer\" type=\"variable\">\n      </left>\n      <value content=\"22\" type=\"Input\"/>\n    </atom>\n    <atom op=\"Equals\">\n      <left var-category=\"FlightInfo\" var=\"is_international\" var-label=\"is_international\" datatype=\"Boolean\" type=\"variable\">\n      </left>\n      <value content=\"true\" type=\"Input\"/>\n    </atom>\n  </and>\n    </if>\n    <then>\n  <var-assign var-category=\"GateResult\" var=\"gate_type\" var-label=\"gate_type\" datatype=\"String\" type=\"variable\">\n    <value content=\"远机位\" type=\"Input\"/>\n  </var-assign>\n  <var-assign var-category=\"GateResult\" var=\"reason\" var-label=\"reason\" datatype=\"String\" type=\"variable\">\n    <value content=\"亚洲低峰时段远机位\" type=\"Input\"/>\n  </var-assign>\n    </then>\n  </rule>\n</rule-set>","create_user":"admin","update_user":"admin","company_id":null,"created_at":1774756333000,"updated_at":1774768140087}]